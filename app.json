{
  "expo": {
    "name": "HandleSports",
    "slug": "handlesports",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/HandleSportsLogoBlack.png",
    "scheme": "handlesports",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.handlesports.app"
    },
    "android": {
      "package": "com.handlesports.app",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}